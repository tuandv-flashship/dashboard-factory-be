# Caddy HTTPS Proxy for local factory development
# Usage: ./bin/caddy run --config Caddyfile
#
# Proxies HTTPS → Octane (FrankenPHP)
# Requires /etc/hosts entries:
#   127.0.0.1  api-dashboard-fls.local api-dashboard-pd.local
#
# Uses port 2443 (MAMP occupies 443)
{
	https_port 2443
	http_port 2080
}

api-dashboard-fls.local {
	reverse_proxy localhost:8000 {
		header_up Host api-dashboard-fls.local
	}
	tls internal
}

api-dashboard-pd.local {
	reverse_proxy localhost:8001 {
		header_up Host api-dashboard-pd.local
	}
	tls internal
}
