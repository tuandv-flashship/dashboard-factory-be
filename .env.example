APP_NAME=PrintDash
APP_ENV=local
APP_KEY=
APP_URL=https://api-dashboard.flashtech.local
API_URL=https://api-dashboard.flashtech.local
FRONTEND_URL="${APP_URL}"
CORS_ALLOWED_ORIGINS=
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

APP_DEBUG=false
# DEBUGBAR_ENABLED=true => force enabled
# DEBUGBAR_ENABLED=null => enabled if APP_DEBUG=true disabled otherwise
# DEBUGBAR_ENABLED=false => disabled
DEBUGBAR_ENABLED=null

HASH_ID=false
HASH_ID_KEY=apiato
HASH_ID_LENGTH=16

GLOBAL_API_RATE_LIMITER_ENABLED=true
GLOBAL_API_RATE_LIMITER_ATTEMPTS_PER_MIN=60
GLOBAL_API_RATE_LIMITER_EXPIRES_IN_MIN=1

PAGINATION_LIMIT_DEFAULT=10
PAGINATION_SKIP=false

API_TOKEN_EXPIRES=1440
API_REFRESH_TOKEN_EXPIRES=43200

AUTH_WELCOME_THROTTLE=120,1
AUTH_REGISTER_THROTTLE=6,1
AUTH_WEB_LOGIN_THROTTLE=10,1
AUTH_WEB_REFRESH_THROTTLE=20,1
AUTH_FORGOT_PASSWORD_THROTTLE=6,1
AUTH_RESET_PASSWORD_THROTTLE=6,1
AUTH_SEND_VERIFICATION_THROTTLE=6,1
AUTH_VERIFY_EMAIL_THROTTLE=20,1

ELOQUENT_QUERY_CACHE=false
ELOQUENT_QUERY_CACHE_TIME=60

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=printdash
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

CLIENT_WEB_ID=
CLIENT_WEB_SECRET=

# Laravel Reverb (WebSocket)
REVERB_APP_ID=printdash
REVERB_APP_KEY=printdash-key
REVERB_APP_SECRET=printdash-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
